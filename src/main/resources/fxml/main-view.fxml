<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="it.unicam.cs.mpgc.rpg129876.controller.MainController"
            styleClass="root">

    <!-- MENU -->
    <top>
        <MenuBar>
            <Menu text="⚔ Gioco">
                <MenuItem text="Nuova Partita" onAction="#onNewGame"/>
                <MenuItem text="Esci" onAction="#onExit"/>
            </Menu>
            <Menu text="❓ Aiuto">
                <MenuItem text="Comandi" onAction="#onHelp"/>
                <MenuItem text="Informazioni" onAction="#onAbout"/>
            </Menu>
        </MenuBar>
    </top>

    <!-- PANNELLO STATISTICHE (SINISTRA) -->
    <left>
        <VBox spacing="10" styleClass="stats-panel" prefWidth="220">
            <padding><Insets top="15" right="10" bottom="15" left="10"/></padding>

            <Label text="📊 STATISTICHE" styleClass="section-title"/>
            <Separator/>

            <Label fx:id="playerNameLabel" styleClass="player-name" text="-"/>
            <Label fx:id="playerClassLabel" styleClass="player-class" text="-"/>

            <Label text="❤️ Salute"/>
            <ProgressBar fx:id="healthBar" prefWidth="180" progress="0"/>
            <Label fx:id="healthLabel" text="0/0"/>

            <Label fx:id="levelLabel" text="⭐ Livello: -"/>
            <Label fx:id="expLabel" text="📈 Esperienza: -"/>
            <Label fx:id="goldLabel" text="💰 Oro: -"/>
            <Label fx:id="attackLabel" text="⚔ Attacco: -"/>
            <Label fx:id="defenseLabel" text="🛡 Difesa: -"/>
        </VBox>
    </left>

    <!-- AREA CENTRALE -->
    <center>
        <VBox spacing="15" alignment="CENTER">
            <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>

            <!-- Schermata iniziale (visibile all'inizio) -->
            <VBox fx:id="startScreen" alignment="CENTER" spacing="20" visible="true">
                <Label text="🏰 DUNGEON EXPLORER RPG 🏰" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #e94560;"/>
                <Label text="Un'avventura epica ti aspetta!" style="-fx-font-size: 18px; -fx-text-fill: #a0a0a0;"/>
                <Button fx:id="startGameBtn" text="✨ INIZIA AVVENTURA ✨" onAction="#onStartGameFromButton"
                        style="-fx-font-size: 20px; -fx-min-width: 250px; -fx-min-height: 60px;
                               -fx-background-color: linear-gradient(to bottom, #e94560, #c72a48);
                               -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 15px;
                               -fx-effect: dropshadow(gaussian, rgba(233,69,96,0.5), 15, 0, 0, 2);"/>
            </VBox>

            <!-- Schermata di gioco (nascosta all'inizio) -->
            <VBox fx:id="gameScreen" spacing="15" alignment="CENTER" visible="false" managed="false">

                <!-- Mappa a griglia -->
                <Label text="🗺️ MAPPA DEL DUNGEON" styleClass="section-title"/>
                <GridPane fx:id="mapGrid" alignment="CENTER" hgap="5" vgap="5"/>

                <Separator/>

                <!-- Descrizione stanza corrente -->
                <TextArea fx:id="roomDescriptionArea" editable="false" wrapText="true"
                          prefHeight="100" styleClass="room-description"/>

                <!-- Bottoni di movimento -->
                <HBox spacing="15" alignment="CENTER">
                    <Button text="⬆ Nord" onAction="#onMoveNorth" styleClass="move-button"/>
                    <Button text="⬅ Ovest" onAction="#onMoveWest" styleClass="move-button"/>
                    <Button text="➡ Est" onAction="#onMoveEast" styleClass="move-button"/>
                    <Button text="⬇ Sud" onAction="#onMoveSouth" styleClass="move-button"/>
                </HBox>

                <!-- Dialogo di combattimento -->
                <VBox fx:id="combatDialog" spacing="10" alignment="CENTER" visible="false" managed="false"
                      style="-fx-background-color: #1a1a2e; -fx-border-color: #e94560; -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 15;">
                    <Label fx:id="combatTitle" text="⚔ COMBATTIMENTO ⚔" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #e94560;"/>
                    <Label fx:id="combatEnemyLabel" text="" style="-fx-font-size: 16px;"/>
                    <ProgressBar fx:id="enemyHealthBar" prefWidth="200" progress="1"/>
                    <Label fx:id="enemyHealthLabel" text=""/>
                    <Label fx:id="combatMessage" text="" style="-fx-font-size: 14px; -fx-text-fill: #a0f0a0;"/>
                    <HBox spacing="15" alignment="CENTER">
                        <Button fx:id="attackBtn" text="⚔ ATTACCA" onAction="#onAttack" styleClass="combat-button"/>
                        <Button fx:id="itemBtn" text="🧪 POZIONE" onAction="#onUseItem" styleClass="combat-button"/>
                        <Button fx:id="fleeBtn" text="🏃 FUGGI" onAction="#onFlee" styleClass="combat-button"/>
                    </HBox>
                </VBox>
            </VBox>
        </VBox>
    </center>

    <!-- PANNELLO INVENTARIO (DESTRA) -->
    <right>
        <VBox spacing="10" styleClass="inventory-panel" prefWidth="200">
            <padding><Insets top="15" right="10" bottom="15" left="10"/></padding>

            <Label text="🎒 INVENTARIO" styleClass="section-title"/>
            <Separator/>

            <VBox fx:id="inventoryList" spacing="5"/>
        </VBox>
    </right>

    <!-- PANNELLO MESSAGGI (BASSO) -->
    <bottom>
        <VBox spacing="10">
            <padding><Insets top="5" right="15" bottom="15" left="15"/></padding>

            <Label text="📜 AVVENTURA" styleClass="section-title"/>
            <ListView fx:id="messageListView" prefHeight="120" styleClass="message-list"/>
        </VBox>
    </bottom>

</BorderPane>