<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="it.unicam.cs.mpgc.rpg129876.controller.MainController"
            styleClass="root">

    <!-- MENU BAR -->
    <top>
        <MenuBar>
            <Menu text="⚔ Gioco">
                <MenuItem text="✨ Nuova Partita" onAction="#onNewGame"/>
                <MenuItem text="❌ Esci" onAction="#onExit"/>
            </Menu>
            <Menu text="🏆 Classifica">
                <MenuItem text="📊 Vedi Classifica" onAction="#onShowLeaderboard"/>
            </Menu>
            <Menu text="❓ Aiuto">
                <MenuItem text="📖 Comandi" onAction="#onHelp"/>
                <MenuItem text="ℹ️ Info" onAction="#onAbout"/>
            </Menu>
        </MenuBar>
    </top>

    <!-- SCHERMATA INIZIALE -->
    <center>
        <VBox fx:id="startScreen" alignment="CENTER" spacing="25" visible="true" managed="true">
            <Label text="🏰 SHADOW OF THE DUNGEON 🏰"
                   style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: #e94560;"/>
            <Label text="⚔ Un'avventura epica ti aspetta ⚔"
                   style="-fx-font-size: 22px; -fx-text-fill: #c0c0c0;"/>
            <Label text="Sconfiggi i 3 draghi e apri la porta del tesoro!"
                   style="-fx-font-size: 14px; -fx-text-fill: #a0a0a0;"/>
            <Button fx:id="startGameBtn" text="✨ INIZIA AVVENTURA ✨" onAction="#onStartGameFromButton"
                    style="-fx-font-size: 24px; -fx-min-width: 320px; -fx-min-height: 75px;
                           -fx-background-color: linear-gradient(to bottom, #e94560, #c72a48);
                           -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 40;
                           -fx-cursor: hand;"/>
        </VBox>
    </center>

    <!-- SCHERMATA DI GIOCO -->
    <BorderPane fx:id="gameScreen" visible="false" managed="false">

        <!-- PANNELLO SINISTRO (STATISTICHE + COMBATTIMENTO) -->
        <left>
            <VBox spacing="10" styleClass="stats-panel" prefWidth="320">
                <padding><Insets top="12" right="10" bottom="12" left="12"/></padding>

                <!-- TITOLO STATISTICHE -->
                <Label text="📊 STATISTICHE" styleClass="section-title" style="-fx-font-size: 14px;"/>
                <Separator/>

                <!-- IMMAGINE PERSONAGGIO -->
                <ImageView fx:id="playerImageView" fitWidth="70" fitHeight="70"
                           style="-fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 10, 0, 0, 2);"/>

                <!-- NOME E CLASSE -->
                <Label fx:id="playerNameLabel" styleClass="player-name" style="-fx-font-size: 18px;" text="-"/>
                <Label fx:id="playerClassLabel" styleClass="player-class" style="-fx-font-size: 13px;" text="-"/>

                <!-- SALUTE -->
                <Label text="❤ SALUTE" style="-fx-font-size: 12px;"/>
                <ProgressBar fx:id="healthBar" prefWidth="270" progress="0"/>
                <Label fx:id="healthLabel" text="0/0" style="-fx-font-size: 12px; -fx-text-fill: #ff6666;"/>

                <!-- ALTRE STATISTICHE -->
                <Label fx:id="levelLabel" text="⭐ Livello: -" style="-fx-font-size: 12px;"/>
                <Label fx:id="expLabel" text="📈 Esperienza: -" style="-fx-font-size: 12px;"/>
                <Label fx:id="goldLabel" text="💰 Oro: -" style="-fx-font-size: 12px;"/>
                <Label fx:id="attackLabel" text="⚔ Attacco: -" style="-fx-font-size: 12px;"/>
                <Label fx:id="defenseLabel" text="🛡 Difesa: -" style="-fx-font-size: 12px;"/>

                <Separator/>

                <!-- SEZIONE COMBATTIMENTO -->
                <Label text="⚔ COMBATTIMENTO ⚔" styleClass="section-title" style="-fx-font-size: 14px;"/>
                <Separator/>

                <VBox fx:id="combatPanel" spacing="10" alignment="CENTER"
                      visible="false" managed="false"
                      style="-fx-background-color: #1a1a2e; -fx-border-color: #e94560; -fx-border-width: 2; -fx-border-radius: 10; -fx-padding: 10;">

                    <!-- VS GIOCATORE VS NEMICO -->
                    <HBox spacing="20" alignment="CENTER">

                        <!-- GIOCATORE -->
                        <VBox alignment="CENTER" spacing="5">
                            <ImageView fx:id="playerCombatImageView" fitWidth="55" fitHeight="55"/>
                            <Label text="GIOCATORE" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                            <ProgressBar fx:id="playerCombatHealthBar" prefWidth="100" progress="1.0"/>
                            <Label fx:id="playerCombatHealthLabel" text="100/100" style="-fx-font-size: 10px; -fx-text-fill: #ff6666;"/>
                        </VBox>

                        <!-- VS CENTRALE -->
                        <Label text="VS" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #e94560;"/>

                        <!-- NEMICO -->
                        <VBox alignment="CENTER" spacing="5">
                            <ImageView fx:id="enemyImageView" fitWidth="55" fitHeight="55"/>
                            <Label fx:id="enemyNameLabel" text="NEMICO" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                            <ProgressBar fx:id="enemyHealthBar" prefWidth="100" progress="1.0"/>
                            <Label fx:id="enemyHealthLabel" text="100/100" style="-fx-font-size: 10px; -fx-text-fill: #ff6666;"/>
                            <HBox spacing="10">
                                <Label fx:id="enemyAttackLabel" text="⚔ -" style="-fx-font-size: 9px; -fx-text-fill: #ffaa66;"/>
                                <Label fx:id="enemyDefenseLabel" text="🛡 -" style="-fx-font-size: 9px; -fx-text-fill: #66aaff;"/>
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- MESSAGGIO COMBATTIMENTO -->
                    <Label fx:id="combatMessage" text="⚔️ Scegli la tua azione! ⚔️"
                           style="-fx-text-fill: yellow; -fx-font-size: 11px; -fx-font-weight: bold;" wrapText="true" alignment="CENTER"/>

                    <!-- SUGGERIMENTO STRATEGICO -->
                    <Label fx:id="potionSuggestion" text="" style="-fx-font-size: 10px; -fx-text-fill: #00ff00;" wrapText="true" alignment="CENTER"/>

                    <!-- BOTTONI AZIONI -->
                    <HBox spacing="10" alignment="CENTER">
                        <Button fx:id="attackBtn" text="⚔ ATTACCA" onAction="#onAttack"
                                style="-fx-font-size: 13px; -fx-min-width: 95px; -fx-min-height: 38px; -fx-background-color: #e94560; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        <Button fx:id="useItemBtn" text="⚗ POZIONE" onAction="#onUseItem"
                                style="-fx-font-size: 13px; -fx-min-width: 95px; -fx-min-height: 38px; -fx-background-color: #2196f3; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        <Button fx:id="fleeBtn" text="🏃 FUGGI" onAction="#onFlee"
                                style="-fx-font-size: 13px; -fx-min-width: 95px; -fx-min-height: 38px; -fx-background-color: #4caf50; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>
            </VBox>
        </left>

        <!-- AREA CENTRALE (MAPPA + STANZA) -->
        <center>
            <VBox spacing="12" alignment="CENTER">
                <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>

                <!-- TITOLO MAPPA -->
                <Label text="🗺 MAPPA DEL DUNGEON" styleClass="section-title" style="-fx-font-size: 16px;"/>

                <!-- MAPPA -->
                <GridPane fx:id="mapGrid" alignment="CENTER" hgap="5" vgap="5"
                          style="-fx-border-color: #e94560; -fx-border-width: 2; -fx-border-radius: 10; -fx-padding: 10;">
                </GridPane>

                <Separator/>

                <!-- STANZA CORRENTE -->
                <HBox spacing="15" alignment="CENTER">
                    <Label text="📍 STANZA" style="-fx-font-weight: bold; -fx-text-fill: #e94560;"/>
                    <TextArea fx:id="roomDescriptionArea" editable="false" wrapText="true"
                              prefHeight="80" prefWidth="350" styleClass="room-description"/>
                </HBox>
            </VBox>
        </center>

        <!-- PANNELLO INVENTARIO E LEGENDA (DESTRA) -->
        <right>
            <VBox spacing="10" styleClass="inventory-panel" prefWidth="230">
                <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>

                <!-- INVENTARIO -->
                <Label text="🎒 INVENTARIO" styleClass="section-title"/>
                <Separator/>
                <VBox fx:id="inventoryList" spacing="5"/>

                <Separator/>

                <!-- LEGENDA CON IMMAGINI (creata da Java) -->
                <VBox fx:id="legendBox" spacing="8"/>

                <Separator/>

                <!-- COMANDI -->
                <Label text="🎮 COMANDI" styleClass="section-title"/>
                <Separator/>
                <VBox spacing="3">
                    <Label text="WASD o FRECCE = Muoviti" style="-fx-text-fill: #a0f0a0; -fx-font-size: 10px;"/>
                    <Label text="⚔ ATTACCA o Z = Colpisci" style="-fx-text-fill: #a0f0a0; -fx-font-size: 10px;"/>
                    <Label text="⚗POZIONE o X = +20 HP(non in combatt.)" style="-fx-text-fill: #a0f0a0; -fx-font-size: 10px;"/>
                    <Label text="⚗POZIONE o X = +?HP(in combatt.)" style="-fx-text-fill: #a0f0a0; -fx-font-size: 10px;"/>
                    <Label text="🏃 FUGGI o C = Scappa (50%)" style="-fx-text-fill: #a0f0a0; -fx-font-size: 10px;"/>
                    <Label text="🏪 MERCANTE = Compra pozioni" style="-fx-text-fill: #a0f0a0; -fx-font-size: 10px;"/>
                </VBox>
            </VBox>
        </right>

        <!-- PANNELLO MESSAGGI (BASSO) -->
        <bottom>
            <VBox spacing="8">
                <padding><Insets top="8" right="15" bottom="10" left="15"/></padding>

                <Label text="📜 LOG AVVENTURA" styleClass="section-title" style="-fx-font-size: 12px;"/>
                <ListView fx:id="messageListView" prefHeight="120" styleClass="message-list"/>
            </VBox>
        </bottom>

    </BorderPane>

</BorderPane>