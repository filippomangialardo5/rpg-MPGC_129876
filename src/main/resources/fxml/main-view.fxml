<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="it.unicam.cs.mpgc.rpg129876.controller.MainController"
            styleClass="root">

    <top>
        <MenuBar>
            <Menu text="⚔ Gioco">
                <MenuItem text="✨ Nuova Partita" onAction="#onNewGame"/>
                <MenuItem text="❌ Esci" onAction="#onExit"/>
            </Menu>
            <Menu text="❓ Aiuto">
                <MenuItem text="📖 Comandi" onAction="#onHelp"/>
                <MenuItem text="ℹ️ Info" onAction="#onAbout"/>
            </Menu>
        </MenuBar>
    </top>

    <!-- SCHERMATA INIZIALE -->
    <center>
        <VBox fx:id="startScreen" alignment="CENTER" spacing="25" visible="true" managed="true">
            <Label text="🏰 DUNGEON EXPLORER RPG 🏰"
                   style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: #e94560;"/>

            <Label text="⚔️ Un'avventura epica ti aspetta! ⚔️"
                   style="-fx-font-size: 22px; -fx-text-fill: #c0c0c0;"/>

            <Button fx:id="startGameBtn" text="✨ INIZIA AVVENTURA ✨" onAction="#onStartGameFromButton"
                    style="-fx-font-size: 24px; -fx-min-width: 320px; -fx-min-height: 75px;
                           -fx-background-color: linear-gradient(to bottom, #e94560, #c72a48);
                           -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 40;
                           -fx-cursor: hand;"/>
        </VBox>
    </center>

    <!-- SCHERMATA DI GIOCO -->
    <BorderPane fx:id="gameScreen" visible="false" managed="false">

        <!-- PANNELLO STATISTICHE -->
        <left>
            <VBox spacing="8" styleClass="stats-panel" prefWidth="260">
                <padding><Insets top="12" right="8" bottom="12" left="12"/></padding>

                <Label text="📊 STATISTICHE" styleClass="section-title"/>
                <Separator/>

                <!-- Per l'immagine del personaggio nelle statistiche -->
                <ImageView fx:id="playerImageView" fitWidth="80" fitHeight="80"
                           style="-fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 10, 0, 0, 2);"/>

                <!-- Per l'immagine del personaggio in combattimento -->
                <ImageView fx:id="playerCombatImageView" fitWidth="60" fitHeight="60"/>

                <!-- Per l'immagine del nemico in combattimento -->
                <ImageView fx:id="enemyImageView" fitWidth="60" fitHeight="60"/>

                <Label fx:id="playerNameLabel" styleClass="player-name" text="-"/>
                <Label fx:id="playerClassLabel" styleClass="player-class" text="-"/>

                <Label text="❤️ SALUTE" style="-fx-font-size: 11px;"/>
                <ProgressBar fx:id="healthBar" prefWidth="210" progress="0"/>
                <Label fx:id="healthLabel" text="0/0" style="-fx-font-size: 11px;"/>

                <Label fx:id="levelLabel" text="⭐ Livello: -" style="-fx-font-size: 11px;"/>
                <Label fx:id="expLabel" text="📈 Esperienza: -" style="-fx-font-size: 11px;"/>
                <Label fx:id="goldLabel" text="💰 Oro: -" style="-fx-font-size: 11px;"/>
                <Label fx:id="attackLabel" text="⚔ Attacco: -" style="-fx-font-size: 11px;"/>
                <Label fx:id="defenseLabel" text="🛡 Difesa: -" style="-fx-font-size: 11px;"/>
            </VBox>
        </left>

        <!-- AREA CENTRALE -->
        <center>
            <VBox spacing="12" alignment="CENTER">
                <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>

                <Label text="🗺️ MAPPA DEL DUNGEON" styleClass="section-title"/>
                <GridPane fx:id="mapGrid" alignment="CENTER" hgap="5" vgap="5"/>

                <Separator/>

                <!-- Stanza corrente -->
                <HBox spacing="15" alignment="CENTER">
                    <Label text="📍 STANZA" style="-fx-font-weight: bold; -fx-text-fill: #e94560;"/>
                    <TextArea fx:id="roomDescriptionArea" editable="false" wrapText="true"
                              prefHeight="70" prefWidth="350" styleClass="room-description"/>
                </HBox>

                <!-- PANNELLO COMBATTIMENTO -->
                <!-- PANNELLO COMBATTIMENTO -->
                <!-- PANNELLO COMBATTIMENTO MINIMALE -->
                <VBox fx:id="combatPanel" spacing="10" alignment="CENTER"
                      visible="false" managed="false"
                      style="-fx-background-color: #1a1a2e; -fx-border-color: #e94560; -fx-border-width: 3; -fx-border-radius: 15; -fx-padding: 15;">

                    <Label text="⚔️ COMBATTIMENTO ⚔️" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #e94560;"/>

                    <Label fx:id="combatMessage" text="Scegli la tua azione!" style="-fx-text-fill: yellow;"/>

                    <HBox spacing="20" alignment="CENTER">
                        <Button fx:id="attackBtn" text="ATTACCA" onAction="#onAttack"
                                style="-fx-font-size: 16px; -fx-min-width: 100px; -fx-min-height: 40px; -fx-background-color: red; -fx-text-fill: white;"/>
                        <Button fx:id="useItemBtn" text="POZIONE" onAction="#onUseItem"
                                style="-fx-font-size: 16px; -fx-min-width: 100px; -fx-min-height: 40px; -fx-background-color: blue; -fx-text-fill: white;"/>
                        <Button fx:id="fleeBtn" text="FUGGI" onAction="#onFlee"
                                style="-fx-font-size: 16px; -fx-min-width: 100px; -fx-min-height: 40px; -fx-background-color: green; -fx-text-fill: white;"/>
                    </HBox>
                </VBox>
            </VBox>
        </center>

        <!-- PANNELLO INVENTARIO -->
        <right>
            <VBox spacing="8" styleClass="inventory-panel" prefWidth="200">
                <padding><Insets top="12" right="12" bottom="12" left="8"/></padding>

                <Label text="🎒 INVENTARIO" styleClass="section-title"/>
                <Separator/>

                <VBox fx:id="inventoryList" spacing="5"/>
            </VBox>
        </right>

        <bottom>
            <VBox spacing="5">
                <padding><Insets top="5" right="12" bottom="10" left="12"/></padding>

                <Label text="📜 LOG" styleClass="section-title" style="-fx-font-size: 11px;"/>
                <ListView fx:id="messageListView" prefHeight="100" styleClass="message-list"/>
            </VBox>
        </bottom>

    </BorderPane>

</BorderPane>